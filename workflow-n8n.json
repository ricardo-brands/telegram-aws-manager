    {
      "parameters": {
        "jsCode": "const CONFIG = {\n  instance_id: 'i-XXXXXXXXXXXXXXXXX',\n  regiao: 'us-east-1'\n};\n\nconst specs = {\n  't2.micro': '1 vCPU, 1 GB RAM',\n  't2.small': '1 vCPU, 2 GB RAM',\n  't2.medium': '2 vCPU, 4 GB RAM',\n  't2.large': '2 vCPU, 8 GB RAM',\n  't3.medium': '2 vCPU, 4 GB RAM',\n  't3.large': '2 vCPU, 8 GB RAM'\n};\n\nconst texto = $input.item.json.message.text.trim().toLowerCase();\nconst comando = texto.split(' ')[0];\nconst parametro = texto.split(' ')[1] || '';\n\nlet resposta_direta = null;\nlet acao_bot = null;\n\n// 🔀 COMANDOS RESTRITOS AWS\nif (comando === '/status') acao_bot = 'status';\nelse if (comando === '/ligar') acao_bot = 'ligar';\nelse if (comando === '/desligar') acao_bot = 'desligar';\nelse if (comando === '/reiniciar') acao_bot = 'reiniciar';\nelse if (comando === '/listar') {\n  resposta_direta = \"📋 *Catálogo AWS:*\\n\\n\";\n  for (const [tipo, spec] of Object.entries(specs)) resposta_direta += `• \\`${tipo}\\` - ${spec}\\n`;\n  acao_bot = 'texto_direto';\n}\nelse if (comando === '/mudar') {\n  if (!specs[parametro]) {\n    resposta_direta = `❌ Tipo '${parametro}' não reconhecido.\\nUse /listar para ver as opções.`;\n    acao_bot = 'texto_direto';\n  } else acao_bot = 'mudar';\n}\n// ℹ️ MENU DE AJUDA\nelse if (comando === '/ajuda' || comando === '/help' || comando === '/start') {\n  resposta_direta = \"☁️ *Controle da AWS:*\\n/status - Ver estado atual\\n/ligar - Iniciar servidor\\n/desligar - Parar servidor\\n/reiniciar - Reiniciar servidor\\n/listar - Ver tamanhos\\n/mudar <tipo> - Alterar capacidade\\n\\n🧠 *Gestão do Servidor (IA):*\\nPode pedir em linguagem natural! Ex:\\n• _'como tá a memória?'_\\n• _'reinicia o apache'_\\n• _'mostra os processos pesados'_\\n• _'quais sites estão ativos?'_\";\n  acao_bot = 'texto_direto';\n}\n// 🤖 LINGUAGEM NATURAL -> VAI PARA O SSH/GEMINI\nelse {\n  acao_bot = 'ssh';\n}\n\nreturn { \n  json: {\n    ...$input.item.json, // Preserva o JSON original para a IA ler a mensagem\n    comando_valido: true,\n    acao: acao_bot,\n    resposta_direta: resposta_direta,\n    parametro: parametro,\n    instance_id: CONFIG.instance_id,\n    regiao: CONFIG.regiao\n  } \n};"
      },
